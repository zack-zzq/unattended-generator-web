@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="main-content">
        <header class="top-bar">
            <div class="d-flex align-center gap-2">
                <h4 class="mt-0 mb-0">@Title</h4>
            </div>
            <div class="d-flex align-center gap-2">
                <a href="generator/preview" class="btn btn-secondary">
                    <span>👁️</span> 预览 XML
                </a>
                <a href="generator/download" class="btn btn-primary">
                    <span>📥</span> 生成 XML
                </a>
            </div>
        </header>

        <main class="content-area">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    发生了未处理的错误。
    <a href="." class="reload">重新加载</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string Title { get; set; } = "Windows 无人值守安装生成器";
}