@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="main-content">
        <header class="top-bar">
            <div class="top-bar-title">
                <div class="top-title">配置工作台</div>
                <p>生成 Windows 安装应答文件 autounattend.xml</p>
            </div>
            <div class="top-bar-actions">
                <a href="generator/preview" class="btn btn-secondary">
                    <AppIcon Name="preview" />
                    <span>预览 XML</span>
                </a>
                <a href="generator/download" class="btn btn-primary">
                    <AppIcon Name="download" />
                    <span>生成 XML</span>
                </a>
            </div>
        </header>

        <main class="content-area">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    发生了未处理的错误。
    <a href="." class="reload">重新加载</a>
    <span class="dismiss">×</span>
</div>
