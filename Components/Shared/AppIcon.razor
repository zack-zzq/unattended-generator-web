<svg class="app-icon @Class" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    @switch (IconName)
    {
        case "dashboard":
            <path d="M4 4h7v7H4z" />
            <path d="M13 4h7v7h-7z" />
            <path d="M4 13h7v7H4z" />
            <path d="M13 13h7v7h-7z" />
            break;
        case "windows":
            <path d="M4 5.5 10.5 4v7H4z" />
            <path d="M12.5 3.5 20 2.4V11h-7.5z" />
            <path d="M4 13h6.5v7L4 18.5z" />
            <path d="M12.5 13H20v8.6l-7.5-1.1z" />
            break;
        case "globe":
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18" />
            <path d="M12 3c2.2 2.3 3.3 5.3 3.3 9S14.2 18.7 12 21" />
            <path d="M12 3C9.8 5.3 8.7 8.3 8.7 12S9.8 18.7 12 21" />
            break;
        case "user":
            <circle cx="12" cy="8" r="4" />
            <path d="M5 20c1.3-3.1 3.7-4.7 7-4.7s5.7 1.6 7 4.7" />
            break;
        case "disk":
            <path d="M6 4h12l2 5v11H4V9z" />
            <path d="M4 9h20" />
            <path d="M8 16h8" />
            break;
        case "optimize":
            <path d="M4 16a8 8 0 1 1 16 0" />
            <path d="M12 16 16 9" />
            <path d="M6.5 16h11" />
            break;
        case "trash":
            <path d="M5 7h14" />
            <path d="M10 11v6" />
            <path d="M14 11v6" />
            <path d="M7 7l1 14h8l1-14" />
            <path d="M9 7V4h6v3" />
            break;
        case "shield":
            <path d="M12 3 19 6v5.5c0 4.2-2.5 7.2-7 9.5-4.5-2.3-7-5.3-7-9.5V6z" />
            break;
        case "script":
            <path d="m8 9-3 3 3 3" />
            <path d="m16 9 3 3-3 3" />
            <path d="m14 6-4 12" />
            break;
        case "advanced":
            <path d="M5 6h14" />
            <path d="M5 12h14" />
            <path d="M5 18h14" />
            <circle cx="9" cy="6" r="2" />
            <circle cx="15" cy="12" r="2" />
            <circle cx="11" cy="18" r="2" />
            break;
        case "preview":
            <path d="M3 12s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" />
            <circle cx="12" cy="12" r="3" />
            break;
        case "download":
            <path d="M12 3v11" />
            <path d="m8 10 4 4 4-4" />
            <path d="M5 19h14" />
            break;
        case "wifi":
            <path d="M4 9a14 14 0 0 1 16 0" />
            <path d="M7.5 12.5a8.5 8.5 0 0 1 9 0" />
            <path d="M11 17h2" />
            break;
        case "clock":
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3 2" />
            break;
        case "palette":
            <path d="M12 4a8 8 0 0 0 0 16h1.5a1.8 1.8 0 0 0 1.1-3.2 1.8 1.8 0 0 1 1.1-3.2H17a4 4 0 0 0 0-8 9.5 9.5 0 0 0-5-1.6z" />
            <circle cx="8.5" cy="10" r=".7" />
            <circle cx="11" cy="7.5" r=".7" />
            <circle cx="14.5" cy="8.5" r=".7" />
            break;
        case "document":
            <path d="M7 3h7l5 5v16H7z" />
            <path d="M14 3v5h5" />
            <path d="M10 13h6" />
            <path d="M10 17h6" />
            break;
        case "copy":
            <path d="M8 8h11v11H8z" />
            <path d="M5 15H4V4h11v1" />
            break;
        case "refresh":
            <path d="M20 7v5h-5" />
            <path d="M4 17v-5h5" />
            <path d="M18.5 9A7 7 0 0 0 6 7.5" />
            <path d="M5.5 15A7 7 0 0 0 18 16.5" />
            break;
        case "settings":
            <circle cx="12" cy="12" r="3" />
            <path d="M19 12a7.7 7.7 0 0 0-.1-1.2l2-1.5-2-3.5-2.4 1a7.6 7.6 0 0 0-2-1.2L14 3h-4l-.5 2.6a7.6 7.6 0 0 0-2 1.2l-2.4-1-2 3.5 2 1.5A7.7 7.7 0 0 0 5 12c0 .4 0 .8.1 1.2l-2 1.5 2 3.5 2.4-1a7.6 7.6 0 0 0 2 1.2L10 21h4l.5-2.6a7.6 7.6 0 0 0 2-1.2l2.4 1 2-3.5-2-1.5c.1-.4.1-.8.1-1.2z" />
            break;
        case "package":
            <path d="M4 8 12 3l8 5-8 5z" />
            <path d="M4 8v8l8 5 8-5V8" />
            <path d="M12 13v8" />
            break;
        case "plus":
            <path d="M12 5v14" />
            <path d="M5 12h14" />
            break;
        case "computer":
            <path d="M4 5h16v11H4z" />
            <path d="M9 20h6" />
            <path d="M12 16v4" />
            break;
        case "lock-open":
            <path d="M7 11h12v10H7z" />
            <path d="M9 11V8a4 4 0 0 1 7.7-1.5" />
            break;
        case "lock":
            <path d="M7 11h12v10H7z" />
            <path d="M9 11V8a4 4 0 0 1 8 0v3" />
            break;
        case "key":
            <circle cx="8" cy="14" r="4" />
            <path d="M12 14h9" />
            <path d="M18 14v3" />
            <path d="M15 14v2" />
            break;
        case "search":
            <circle cx="11" cy="11" r="6" />
            <path d="m16 16 4 4" />
            break;
        case "volume":
            <path d="M5 9h4l5-4v14l-5-4H5z" />
            <path d="M17 9.5a5 5 0 0 1 0 5" />
            break;
        case "pin":
            <path d="M12 21s6-5.3 6-11a6 6 0 1 0-12 0c0 5.7 6 11 6 11z" />
            <circle cx="12" cy="10" r="2" />
            break;
        case "image":
            <path d="M4 5h16v14H4z" />
            <path d="m7 16 4-4 3 3 2-2 3 3" />
            <circle cx="9" cy="9" r="1" />
            break;
        case "check":
            <circle cx="12" cy="12" r="9" />
            <path d="m8 12 3 3 6-7" />
            break;
        case "warning":
            <path d="M12 4 21 20H3z" />
            <path d="M12 9v5" />
            <path d="M12 17h.01" />
            break;
        case "error":
            <circle cx="12" cy="12" r="9" />
            <path d="m9 9 6 6" />
            <path d="m15 9-6 6" />
            break;
        case "chevron-right":
            <path d="m9 6 6 6-6 6" />
            break;
        case "chevron-down":
            <path d="m6 9 6 6 6-6" />
            break;
        default:
            <circle cx="12" cy="12" r="8" />
            <path d="M12 8v4" />
            <path d="M12 16h.01" />
            break;
    }
</svg>

@code {
    [Parameter] public string? Name { get; set; }
    [Parameter] public string Class { get; set; } = "";

    private string IconName => Normalize(Name);

    private static string Normalize(string? icon)
    {
        return icon switch
        {
            "🏠" => "dashboard",
            "💿" or "📀" => "windows",
            "🌐" => "globe",
            "👤" or "👑" => "user",
            "💾" => "disk",
            "⚡" => "optimize",
            "🗑️" => "trash",
            "🔐" or "🔒" or "🛡️" => "shield",
            "📜" => "script",
            "🔧" or "⚙️" => "advanced",
            "👁️" => "preview",
            "📥" => "download",
            "📶" => "wifi",
            "🕐" => "clock",
            "🎨" => "palette",
            "📄" or "📋" or "📖" => "document",
            "📦" => "package",
            "➕" => "plus",
            "💻" or "🖥️" => "computer",
            "🔓" => "lock-open",
            "🔑" => "key",
            "🔍" => "search",
            "🔊" => "volume",
            "📌" or "📍" => "pin",
            "🖼️" => "image",
            _ => string.IsNullOrWhiteSpace(icon) ? "document" : icon
        };
    }
}
