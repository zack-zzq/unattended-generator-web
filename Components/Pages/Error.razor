@page "/Error"

<PageTitle>Error</PageTitle>

<div class="content-area">
    <h1>发生错误</h1>
    <h2 class="text-danger">处理您的请求时发生了错误。</h2>

    <p class="text-muted">
        请刷新页面或返回首页重试。
    </p>

    <a href="/" class="btn btn-primary">返回首页</a>
</div>

@code {
    // WASM版本不需要RequestId，因为没有服务器端HttpContext
}